# GoodVibes ACP Runtime — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API key — backward-compat fallback for the Anthropic provider.
# Obtain from https://console.anthropic.com/
#
# NOTE: Provider and model selection is now configured in goodvibes.config.json
# via the `models` section. This env var is used as a fallback API key for the
# Anthropic provider when no key has been supplied by the ACP client.
#
# ACP-compliant clients (e.g. Zed) pass API keys through their own settings;
# this env var is only needed for direct CLI usage or local development.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to validate incoming webhook signatures.
# Set to a long, random string. Used by HttpListener in the external HTTP layer.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# =============================================================================
# OPTIONAL — Runtime Mode & Daemon
# =============================================================================

# Runtime mode. Set to "daemon" to run as a background daemon process.
# Equivalent to passing --daemon on the CLI.
# Default: subprocess
# GOODVIBES_MODE=daemon

# TCP port the daemon server listens on.
# Equivalent to passing --port on the CLI.
# Default: 9000
# GOODVIBES_DAEMON_PORT=9000

# Host/interface the daemon binds to.
# Equivalent to passing --host on the CLI.
# Default: 127.0.0.1
# GOODVIBES_DAEMON_HOST=127.0.0.1

# TCP port for the daemon health-check endpoint.
# Equivalent to passing --health-port on the CLI.
# Default: GOODVIBES_DAEMON_PORT + 1 (e.g. 9001 when port is 9000)
# GOODVIBES_DAEMON_HEALTH_PORT=9001

# Path to the PID file written when running as a daemon.
# Equivalent to passing --pid-file on the CLI.
# Default: none (optional — daemon runs without a PID file if unset)
# GOODVIBES_DAEMON_PID_FILE=/tmp/goodvibes.pid

# =============================================================================
# OPTIONAL — Config Overrides (GOODVIBES_{SECTION}__{KEY} format)
# These override values in the runtime config object at startup.
# =============================================================================
#
# Any config key can be overridden using the GOODVIBES_{SECTION}__{KEY} pattern.
# These are common examples:

# Override runtime.port config key.
# GOODVIBES_RUNTIME__PORT=9000

# Override logging.level config key.
# Accepted values: debug | info | warn | error
# GOODVIBES_LOGGING__LEVEL=info

# Override wrfc.enableQualityGates config key.
# Set to "true" to enforce minimum review scores before accepting agent output.
# GOODVIBES_WRFC__ENABLE_QUALITY_GATES=true

# Override agents.maxParallel config key.
# Maximum number of agent tasks that may run concurrently.
# GOODVIBES_AGENTS__MAX_PARALLEL=4

# =============================================================================
# TEST-ONLY — Not used in production
# =============================================================================

# Used in config layer tests to exercise multi-source port resolution.
# OTHER_RUNTIME_PORT=9999

# Used in project analyzer tests as a generic API key fixture.
# API_KEY=test-api-key-value
